# 복사해서 .env 로 만드세요:  cp .env.example .env
# (.env 는 .gitignore 처리되어 커밋되지 않습니다)

# 필요한 건 이 한 줄뿐입니다. 무료 키 발급: https://cloud.cerebras.ai
# → 무료 3모델을 같은 우선순위로 라운드로빈하며, 분당 요청 제한을 자동 준수합니다.
CEREBRAS_API_KEY=csk-...

# (선택) LLM 요청 타임아웃(초, 기본 120)
#LLM_TIMEOUT=120

# 다른 프로바이더(OpenRouter, OpenAI, 로컬 등)를 섞어 쓰고 싶다면
# docs/configuration.md 의 슬롯 설정을 참고하세요.
